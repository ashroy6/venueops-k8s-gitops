Vagrant.configure("2") do |config|
  config.vm.boot_timeout = 600
  config.ssh.insert_key = false
  config.vm.box = "bento/ubuntu-22.04"

  config.vm.provider "virtualbox" do |vb|
    vb.gui = false
  end

  nodes = [
    {
      name: "kl-cp-1",
      ip: "192.168.56.10",
      role: "control-plane",
      cpus: 2,
      memory: 3072
    },
    {
      name: "kl-cp-2",
      ip: "192.168.56.11",
      role: "control-plane",
      cpus: 2,
      memory: 2560
    },
    {
      name: "kl-cp-3",
      ip: "192.168.56.12",
      role: "control-plane",
      cpus: 2,
      memory: 2560
    },
    {
      name: "kl-worker-1",
      ip: "192.168.56.21",
      role: "worker",
      cpus: 2,
      memory: 4096
    },
    {
      name: "kl-worker-2",
      ip: "192.168.56.22",
      role: "worker",
      cpus: 2,
      memory: 4096
    }
  ]

  nodes.each do |node|
    config.vm.define node[:name] do |machine|
      machine.vm.hostname = node[:name]
      machine.vm.network "private_network", ip: node[:ip]

      machine.vm.provider "virtualbox" do |vb|
        vb.name = node[:name]
        vb.cpus = node[:cpus]
        vb.memory = node[:memory]
      end

      machine.vm.provision "shell", inline: <<-SHELL
        set -e

        echo "#{node[:ip]} #{node[:name]}" | sudo tee -a /etc/hosts
        echo "Node role: #{node[:role]}" | sudo tee /etc/kl-node-role

        echo "Disabling swap for Kubernetes..."
        sudo swapoff -a || true

        sudo cp /etc/fstab /etc/fstab.bak.$(date +%Y%m%d%H%M%S) || true

        sudo sed -i '/ swap / s/^/# DISABLED_FOR_KUBERNETES /' /etc/fstab || true
        sudo sed -i '/swapfile/ s/^/# DISABLED_FOR_KUBERNETES /' /etc/fstab || true

        sudo systemctl mask swap.target || true

        echo "Swap status after disable:"
        free -h
      SHELL

      machine.vm.provision "shell", path: "scripts/prepare-node.sh"

      if node[:role] == "control-plane"
        machine.vm.provision "shell", path: "scripts/setup-ha-api.sh"
      end
    end
  end
end