Vagrant.configure("2") do |config|
  config.vm.boot_timeout = 600
  config.ssh.insert_key = false
  config.vm.box = "bento/ubuntu-22.04"

  config.vm.provider "virtualbox" do |vb|
    vb.gui = false
  end

  nodes = [
    {
      name: "kl-cp-1",
      ip: "192.168.56.10",
      role: "control-plane",
      cpus: 2,
      memory: 3072
    },
    {
      name: "kl-cp-2",
      ip: "192.168.56.11",
      role: "control-plane",
      cpus: 2,
      memory: 2048
    },
    {
      name: "kl-cp-3",
      ip: "192.168.56.12",
      role: "control-plane",
      cpus: 2,
      memory: 2048
    },
    {
      name: "kl-worker-1",
      ip: "192.168.56.21",
      role: "worker",
      cpus: 2,
      memory: 3072
    },
    {
      name: "kl-worker-2",
      ip: "192.168.56.22",
      role: "worker",
      cpus: 2,
      memory: 3072
    },
    {
      name: "kl-worker-3",
      ip: "192.168.56.23",
      role: "worker",
      cpus: 2,
      memory: 2048
    },
    {
      name: "kl-worker-4",
      ip: "192.168.56.24",
      role: "worker",
      cpus: 2,
      memory: 2048
    }
  ]

  hosts_entries = nodes.map { |n| "#{n[:ip]} #{n[:name]}" }.join("\n")

  nodes.each do |node|
    config.vm.define node[:name] do |machine|
      machine.vm.hostname = node[:name]
      machine.vm.network "private_network", ip: node[:ip]

      machine.vm.provider "virtualbox" do |vb|
        vb.name = node[:name]
        vb.cpus = node[:cpus]
        vb.memory = node[:memory]
      end

      machine.vm.provision "shell", inline: <<-SHELL
        set -e

        echo "==> Writing KL cluster hosts entries"

        cat <<'HOSTS' | sudo tee /tmp/kl-hosts >/dev/null
#{hosts_entries}
HOSTS

        sudo sed -i '/kl-cp-1/d;/kl-cp-2/d;/kl-cp-3/d;/kl-worker-1/d;/kl-worker-2/d;/kl-worker-3/d;/kl-worker-4/d' /etc/hosts
        cat /tmp/kl-hosts | sudo tee -a /etc/hosts >/dev/null

        echo "==> Writing KL node role"
        echo "#{node[:role]}" | sudo tee /etc/kl-node-role >/dev/null

        echo "==> Node identity"
        hostname
        cat /etc/kl-node-role

        echo "==> Current /etc/hosts KL entries"
        grep 'kl-' /etc/hosts || true
      SHELL

      machine.vm.provision "shell", path: "scripts/prepare-node.sh"

      if node[:role] == "control-plane"
        machine.vm.provision "shell", path: "scripts/setup-ha-api.sh"
      end
    end
  end
end