{
  "id": null,
  "uid": "kl-node-overview",
  "title": "KL Kubernetes Platform Overview",
  "tags": ["kubernetes", "node-exporter", "kube-state-metrics", "prometheus", "kl"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "type": "text",
      "title": "Section 1: Cluster Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Section 1: Cluster Health"
      }
    },
    {
      "type": "stat",
      "title": "Nodes Ready",
      "gridPos": { "x": 0, "y": 2, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "Ready nodes",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods Running",
      "gridPos": { "x": 5, "y": 2, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "Running pods",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods Pending",
      "gridPos": { "x": 10, "y": 2, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Pending\"})",
          "legendFormat": "Pending pods",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods Failed",
      "gridPos": { "x": 15, "y": 2, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Failed\"})",
          "legendFormat": "Failed pods",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods Not Ready",
      "gridPos": { "x": 19, "y": 2, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_pod_status_ready{condition=\"false\"})",
          "legendFormat": "Not ready pods",
          "refId": "A"
        }
      ]
    },

    {
      "type": "text",
      "title": "Section 2: Workload Health",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Section 2: Workload Health"
      }
    },
    {
      "type": "stat",
      "title": "Deployment Replicas Available",
      "gridPos": { "x": 0, "y": 9, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_available)",
          "legendFormat": "Available replicas",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Deployment Replicas Mismatch",
      "gridPos": { "x": 6, "y": 9, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_deployment_spec_replicas - kube_deployment_status_replicas_available)",
          "legendFormat": "Missing replicas",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Restarts in Last 15 Minutes",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total[15m]))",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Waiting Containers by Reason",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (namespace, pod, container, reason) (kube_pod_container_status_waiting_reason)",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}}/{{reason}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },

    {
      "type": "text",
      "title": "Section 3: Node Health",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Section 3: Node Health"
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage by Node",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage by Node",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Root Filesystem Usage",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{fstype!=\"tmpfs\",mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{fstype!=\"tmpfs\",mountpoint=\"/\"})",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Network Receive / Transmit by Node",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{device!=\"lo\"}[5m]))",
          "legendFormat": "{{instance}} receive",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m]))",
          "legendFormat": "{{instance}} transmit",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },

    {
      "type": "text",
      "title": "Section 4: Platform Components",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Section 4: Platform Components"
      }
    },
    {
      "type": "stat",
      "title": "Prometheus Targets Down",
      "gridPos": { "x": 0, "y": 41, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(up == 0)",
          "legendFormat": "Targets down",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DaemonSet Unavailable Pods",
      "gridPos": { "x": 6, "y": 41, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kube_daemonset_status_desired_number_scheduled - kube_daemonset_status_number_available)",
          "legendFormat": "Unavailable daemonset pods",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "kube-state-metrics Up",
      "gridPos": { "x": 12, "y": 41, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(up{job=~\".*kube.*state.*|.*kube-state-metrics.*\"})",
          "legendFormat": "kube-state-metrics",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "node-exporter Up",
      "gridPos": { "x": 18, "y": 41, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(up{job=~\".*node.*exporter.*|.*node-exporter.*\"})",
          "legendFormat": "node-exporter",
          "refId": "A"
        }
      ]
    }
  ]
}